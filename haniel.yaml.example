# Full haniel configuration example — multi-service setup.
#
# Directory structure (see docs/adr/0003-directory-structure.md):
#   {root}/
#   +-- haniel.yaml            <- this file
#   +-- .self/                 <- haniel repo (self-update)
#   +-- .services/
#       +-- my-app/            <- cloned repo
#       |   +-- logs/          <- service stdout/stderr
#       +-- my-lib/            <- cloned repo

poll_interval: 60

shutdown:
  timeout: 10
  kill_timeout: 30

backoff:
  base_delay: 5
  max_delay: 300
  circuit_breaker: 5
  circuit_window: 300

webhooks:
  - url: https://hooks.slack.com/services/T.../B.../...
    format: slack

mcp:
  enabled: true
  transport: sse
  port: 3200

repos:
  haniel:
    url: https://github.com/eiaserinnys/Haniel.git
    branch: main
    path: ./.self

  my-app:
    url: git@github.com:org/my-app.git
    branch: main
    path: ./.services/my-app

  my-lib:
    url: git@github.com:org/my-lib.git
    branch: main
    path: ./.services/my-lib

self:
  repo: haniel
  auto_update: false

services:
  # MCP servers (no `after`, start in parallel)
  mcp-slack:
    run: npx -y supergateway --stdio "npx -y @anthropic/mcp-slack" --port 3101
    cwd: ./.services/my-app
    restart_delay: 3

  mcp-my-app:
    run: ./runtime/venv/Scripts/python.exe -m my_app.mcp --port=3104
    cwd: ./.services/my-app
    repo: my-app
    ready: port:3104
    restart_delay: 3
    hooks:
      post_pull: ./runtime/venv/Scripts/pip.exe install -r ./.services/my-app/requirements.txt

  # Main service (depends on MCP)
  bot:
    run: ./runtime/venv/Scripts/python.exe -m my_app.bot
    cwd: ./.services/my-app
    repo: my-app
    after: mcp-my-app
    shutdown:
      signal: SIGTERM
      timeout: 15
    hooks:
      post_pull: ./runtime/venv/Scripts/pip.exe install -r ./.services/my-app/requirements.txt

install:
  requirements:
    python: ">=3.11"
    node: ">=18"
    winsw: true
    claude-code: true

  directories:
    - ./.self/logs
    - ./.services
    - ./runtime
    - ./runtime/logs
    - ./runtime/data

  environments:
    main-venv:
      type: python-venv
      path: ./runtime/venv
      requirements:
        - ./.services/my-app/requirements.txt

    runtime-node:
      type: npm
      path: ./.services/my-app

  configs:
    app-env:
      path: ./.services/my-app/.env
      keys:
        - key: SLACK_BOT_TOKEN
          prompt: "Slack Bot Token (xoxb-...)"
          guide: "https://api.slack.com/apps -> select app -> OAuth & Permissions -> Bot User OAuth Token"
        - key: DEBUG
          default: "false"

    app-mcp:
      path: ./.services/my-app/.mcp.json
      content: |
        {
          "mcpServers": {
            "my-app-mcp": { "url": "http://localhost:3104/sse" },
            "haniel": { "url": "http://localhost:3200/sse" },
            "slack": { "url": "http://localhost:3101/sse" }
          }
        }

  service:
    name: haniel
    display: "Haniel Service Runner"
    working_directory: "{root}"
    environment:
      PYTHONUTF8: "1"
