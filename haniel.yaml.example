# Full haniel configuration example.
#
# This example shows a multi-service setup with:
# - Multiple git repositories
# - Service dependency ordering (after/ready)
# - Lifecycle hooks (post_pull)
# - Self-update configuration
# - Interactive installation (Claude Code-assisted secret collection)

poll_interval: 60

shutdown:
  timeout: 10
  kill_timeout: 30

backoff:
  base_delay: 5
  max_delay: 300
  circuit_breaker: 5
  circuit_window: 300

webhooks:
  - url: https://hooks.slack.com/services/T.../B.../...
    format: slack

mcp:
  enabled: true
  transport: sse
  port: 3200

repos:
  haniel:
    url: git@github.com:eiaserinnys/Haniel.git
    branch: main
    path: ./.projects/haniel

  my-app:
    url: git@github.com:org/my-app.git
    branch: main
    path: ./.projects/my-app

  my-lib:
    url: git@github.com:org/my-lib.git
    branch: main
    path: ./.projects/my-lib

self:
  repo: haniel
  auto_update: false

services:
  # MCP servers (no `after`, start in parallel)
  mcp-slack:
    run: npx -y supergateway --stdio "npx -y @anthropic/mcp-slack" --port 3101
    cwd: ./runtime
    restart_delay: 3

  mcp-my-app:
    run: ./runtime/venv/Scripts/python.exe -m my_app.mcp --port=3104
    cwd: ./workspace
    repo: my-app
    ready: port:3104
    restart_delay: 3
    hooks:
      post_pull: ./runtime/venv/Scripts/pip.exe install -r ./runtime/requirements.txt

  # Main service (depends on MCP)
  bot:
    run: ./runtime/venv/Scripts/python.exe -m my_app.bot
    cwd: ./workspace
    repo: my-app
    after: mcp-my-app
    shutdown:
      signal: SIGTERM
      timeout: 15
    hooks:
      post_pull: ./runtime/venv/Scripts/pip.exe install -r ./runtime/requirements.txt

install:
  requirements:
    python: ">=3.11"
    node: ">=18"
    winsw: true
    claude-code: true

  directories:
    - ./runtime
    - ./runtime/logs
    - ./runtime/data
    - ./workspace
    - ./workspace/.local
    - ./workspace/.local/tmp

  environments:
    main-venv:
      type: python-venv
      path: ./runtime/venv
      requirements:
        - ./runtime/requirements.txt

    runtime-node:
      type: npm
      path: ./runtime

  configs:
    workspace-env:
      path: ./workspace/.env
      keys:
        - key: SLACK_BOT_TOKEN
          prompt: "Slack Bot Token (xoxb-...)"
          guide: "https://api.slack.com/apps -> select app -> OAuth & Permissions -> Bot User OAuth Token"
          validate: "curl -s -H 'Authorization: Bearer {value}' https://slack.com/api/auth.test | jq -e '.ok'"
        - key: SLACK_APP_TOKEN
          prompt: "Slack App Token (xapp-...)"
          guide: "https://api.slack.com/apps -> select app -> Basic Information -> App-Level Tokens"
        - key: DEBUG
          default: "false"

    workspace-mcp:
      path: ./workspace/.mcp.json
      content: |
        {
          "mcpServers": {
            "my-app-mcp": { "url": "http://localhost:3104/sse" },
            "haniel": { "url": "http://localhost:3200/sse" },
            "slack": { "url": "http://localhost:3101/sse" }
          }
        }

    webhook-config:
      path: ./runtime/data/watchdog_config.json
      keys:
        - key: slackWebhookUrl
          prompt: "Slack Webhook URL (for notifications)"
          guide: "https://api.slack.com/apps -> Incoming Webhooks -> Webhook URL"

  service:
    name: haniel
    display: "Haniel Service Runner"
    working_directory: "{root}"
    environment:
      PYTHONUTF8: "1"
